{
  "name": "boilerplate-typescript-todo",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": {
    "packages": [
      "packages/backend",
      "packages/frontend",
      "packages/shared/*"
    ]
  },
  "scripts": {
    "ci": "turbo run ci",
    "postinstall": "yarn run build:types",
    "dev": "dotenv -- turbo dev",
    "build": "turbo run build",
    "build:types": "turbo run build --filter=@boilerplate-typescript-todo/types",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "turbo run format:check",
    "prepare": "husky",
    "test:int": "dotenv -e .env -- turbo run test:int",
    "test:benchmark": "bash ./scripts/benchmarks/run-benchmarks.sh",
    "scaffold:frontend": "npx tsx scripts/scaffolding/frontend-module.ts",
    "scaffold:backend": "npx tsx scripts/scaffolding/backend-module.ts"
  },
  "license": "MIT",
  "resolutions": {
    "@nestjs/common": "11.0.0",
    "@nestjs/core": "11.0.0",
    "@nestjs/terminus": "11.0.0",
    "@nestjs/typeorm": "11.0.0",
    "@fastify/middie": "^9.1.0",
    "minimatch": "^10.2.2",
    "fastify": "^5.7.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "turbo": "^2.5.5"
  },
  "engines": {
    "node": ">=22.12.0",
    "yarn": ">=1.22.0"
  }
}
